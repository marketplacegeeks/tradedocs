# Required environment variables for the frontend.
# Copy this file to .env.local and fill in values for local development.
# In production, Railway injects these as service environment variables at build time.

# URL of the Django API (must include /api/v1).
# Local dev:  http://localhost:8000/api/v1
# Production: set in Railway frontend service → Variables tab
VITE_API_BASE_URL=http://localhost:8000/api/v1
